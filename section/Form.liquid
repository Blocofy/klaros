{%- liquid
  assign color_scheme = props.color_scheme | default: 'scheme-1'
  assign alignment = props.alignment | default: 'left'
  assign pad_top = props.padding_top | default: 80
  assign pad_bottom = props.padding_bottom | default: 80
  assign form = props.form
-%}
<section
  class="section color-{{ color_scheme }}"
  style="--section-padding-top: {{ pad_top }}px; --section-padding-bottom: {{ pad_bottom }}px;"
>
  <div class="wrap">
    <div style="{% if alignment == 'center' %}max-width: 42rem; margin: 0 auto;{% endif %}">
      {%- if props.eyebrow or props.heading or props.description -%}
        <div class="section__lead" style="margin-bottom: 2rem;{% if alignment == 'center' %}text-align: center;{% endif %}">
          {%- if props.eyebrow and props.eyebrow != blank -%}
            <span class="eyebrow">{{ props.eyebrow }}</span>
          {%- endif -%}
          {%- if props.heading and props.heading != blank -%}
            <h2>{{ props.heading }}</h2>
          {%- endif -%}
          {%- if props.description and props.description != blank -%}
            <p style="margin-top: 0.5rem; opacity: 0.75;">{{ props.description }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if form == nil -%}
        {%- comment -%} Editör-içi tanı; canlıda hiçbir şey gösterme (platform kuralı). {%- endcomment -%}
        {%- if in_editor -%}
          <div class="form-missing" style="border:1px dashed var(--color-border,#d4d4d8); padding:1rem 1.25rem; border-radius:.6rem; opacity:.75; font-size:.9rem;">
            Form bulunamadı. Sağ panelden bir <strong>form</strong> seçin (Form anahtarı) ya da
            <strong>Formlar &rsaquo; Form Kurucu</strong>'da yeni bir form oluşturun.
          </div>
        {%- endif -%}
      {%- else -%}
        <form
          class="form form--cols-{{ form.config.layout.columns | default: 1 }}"
          id="{{ section.id }}"
          enctype="multipart/form-data"
          method="post"
          action="/api/forms/{{ form.key }}/submit"
          data-bcf-form
          data-success="{{ form.config.messages.success | default: 'Teşekkürler, mesajınız alındı.' | escape }}"
          data-error="{{ form.config.messages.error | default: 'Gönderilemedi.' | escape }}"
        >
          <div class="form-grid form-grid--cols-{{ form.config.layout.columns | default: 1 }} form-grid--gap-{{ form.config.layout.gap | default: 'md' }}">
            {%- for field in form.fields -%}
              {% render 'partial/form-field-v2', field: field %}
            {%- endfor -%}
          </div>
          <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true"
                 style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
          {%- if form.config.consent -%}
            <div class="form-consent">
              {%- for item in form.config.consent.items -%}
                <label class="form-consent__item">
                  <input type="checkbox" name="_consent_{{ item.key }}" value="1"{% if item.required %} required{% endif %}>
                  <span class="form-consent__text">
                    {%- if item.link_url and item.link_url != blank -%}
                      <a href="{{ item.link_url }}" target="_blank" rel="noopener">{{ item.label }}</a>
                    {%- else -%}
                      {{ item.label }}
                    {%- endif -%}
                    {%- if item.required %} <span class="ff__req">*</span>{% endif -%}
                  </span>
                </label>
              {%- endfor -%}
              <input type="hidden" name="_consent_version" value="{{ form.config.consent.version }}">
            </div>
          {%- endif -%}
          <div class="form-actions form-actions--{{ form.config.submit.alignment | default: 'left' }}">
            <button class="btn btn--{{ form.config.submit.style | default: 'primary' }}" type="submit">
              {{ form.config.submit.label | default: 'Gönder' }}
            </button>
            <span class="form-status" role="status"></span>
          </div>
        </form>
        {% render 'partial/form-script-v2', form_id: section.id %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Form",
  "category": "Form",
  "settings": [
    { "type": "header", "label": "Başlık" },
    { "type": "text", "id": "eyebrow", "label": "Üst başlık" },
    { "type": "text", "id": "heading", "label": "Başlık" },
    { "type": "textarea", "id": "description", "label": "Alt metin", "rows": 2 },

    { "type": "header", "label": "Form" },
    { "type": "text", "id": "form_key", "label": "Form (anahtar)", "help": "Form Kurucu'da oluşturduğunuz formun anahtarı (forms.key). Alanlar, stiller ve ayarlar formun tanımından gelir." },

    { "type": "header", "label": "Düzen" },
    { "type": "alignment", "id": "alignment", "label": "Hizalama" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 200, "step": 8, "suffix": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 200, "step": 8, "suffix": "px" },

    { "type": "header", "label": "Renk" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması" }
  ],
  "presets": [
    {
      "name": "Form",
      "settings": {
        "heading": "Bize ulaşın",
        "description": "Formu doldurun, en kısa sürede dönüş yapalım.",
        "alignment": "left",
        "color_scheme": "scheme-1"
      }
    }
  ]
}
{% endschema %}
