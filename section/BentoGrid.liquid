{%- liquid
  assign color_scheme = props.color_scheme | default: 'scheme-1'
  assign cols = props.columns | default: '4'
  assign align = props.alignment | default: 'left'
  assign pad_top = props.padding_top | default: 80
  assign pad_bottom = props.padding_bottom | default: 80
-%}
<section
  class="section color-{{ color_scheme }}"
  style="--section-padding-top: {{ pad_top }}px; --section-padding-bottom: {{ pad_bottom }}px;"
>
  <div class="wrap">
    {%- if props.eyebrow or props.title or props.subtitle -%}
      <div class="section__lead{% if align == 'center' %} section__lead--center{% endif %}">
        {%- if props.eyebrow and props.eyebrow != blank -%}
          <span class="eyebrow" data-yt-bind="eyebrow">{{ props.eyebrow }}</span>
        {%- endif -%}
        {%- if props.title and props.title != blank -%}
          <h2 data-yt-bind="title">{{ props.title }}</h2>
        {%- endif -%}
        {%- if props.subtitle and props.subtitle != blank -%}
          <p data-yt-bind="subtitle">{{ props.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="bento bento--cols-{{ cols }}">
      {%- for block in blocks -%}
        {%- if block.type == 'bento-item' -%}
          {% render 'block/bento-item', block: block %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bento ızgara",
  "category": "İçerik",
  "settings": [
    { "type": "header", "label": "Başlık" },
    { "type": "text", "id": "eyebrow", "label": "Üst başlık" },
    { "type": "text", "id": "title", "label": "Bölüm başlığı", "bindable": true },
    { "type": "textarea", "id": "subtitle", "label": "Alt metin", "rows": 2 },

    { "type": "header", "label": "Düzen" },
    { "type": "select", "id": "columns", "label": "Sütun sayısı", "options": [
      { "label": "2 sütun", "value": "2" },
      { "label": "3 sütun", "value": "3" },
      { "label": "4 sütun", "value": "4" }
    ]},
    { "type": "alignment", "id": "alignment", "label": "Başlık hizalama" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 200, "step": 8, "suffix": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 200, "step": 8, "suffix": "px" },

    { "type": "header", "label": "Renk" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması" }
  ],
  "blocks": [
    { "type": "bento-item", "max": 16 }
  ],
  "presets": [
    {
      "name": "Bento — 4 hücre",
      "settings": { "title": "Öne çıkanlar", "columns": "4", "alignment": "left", "color_scheme": "scheme-1" },
      "blocks": [
        { "type": "bento-item", "settings": { "col_span": "2", "row_span": "2", "eyebrow": "ÖNE ÇIKAN", "heading": "Geniş hücre", "text": "İki sütun, iki satır kaplayan vurgulu hücre.", "content_align": "left" } },
        { "type": "bento-item", "settings": { "col_span": "2", "row_span": "1", "heading": "Yatay hücre", "text": "İki sütunluk yatay alan." } },
        { "type": "bento-item", "settings": { "col_span": "1", "row_span": "1", "heading": "Küçük" } },
        { "type": "bento-item", "settings": { "col_span": "1", "row_span": "1", "heading": "Küçük" } }
      ]
    },
    {
      "name": "Bento — 3 sütun eşit",
      "settings": { "title": "Özellikler", "columns": "3", "alignment": "center", "color_scheme": "scheme-1" },
      "blocks": [
        { "type": "bento-item", "settings": { "heading": "Birinci", "text": "Açıklama metni.", "content_align": "center" } },
        { "type": "bento-item", "settings": { "heading": "İkinci", "text": "Açıklama metni.", "content_align": "center" } },
        { "type": "bento-item", "settings": { "heading": "Üçüncü", "text": "Açıklama metni.", "content_align": "center" } }
      ]
    }
  ]
}
{% endschema %}
