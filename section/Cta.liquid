{%- liquid
  assign color_scheme = props.color_scheme | default: 'scheme-2'
  assign alignment = props.alignment | default: 'center'
  assign pad_top = props.padding_top | default: 80
  assign pad_bottom = props.padding_bottom | default: 80
-%}
<section
  class="section color-{{ color_scheme }}"
  style="--section-padding-top: {{ pad_top }}px; --section-padding-bottom: {{ pad_bottom }}px;"
>
  <div class="wrap">
    <div class="cta cta--{{ alignment }}">
      <div class="cta__content">
        {%- if props.eyebrow and props.eyebrow != blank -%}
          <span class="eyebrow" data-yt-bind="eyebrow">{{ props.eyebrow }}</span>
        {%- endif -%}
        <h2 data-yt-bind="heading">{{ props.heading | default: 'Hadi başlayalım' }}</h2>
        {%- if props.body and props.body != blank -%}
          <p class="cta__body" data-yt-bind="body">{{ props.body }}</p>
        {%- endif -%}
      </div>

      {%- if props.primary_button_label and props.primary_button_label != blank -%}
        <div class="cta__actions">
          <a class="btn btn--primary" data-yt-bind="primary_button_label" href="{{ props.primary_button_url | default: '#' }}">{{ props.primary_button_label }}</a>
          {%- if props.secondary_button_label and props.secondary_button_label != blank -%}
            <a class="btn btn--secondary" data-yt-bind="secondary_button_label" href="{{ props.secondary_button_url | default: '#' }}">{{ props.secondary_button_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Çağrı (CTA)",
  "category": "Aksiyon",
  "settings": [
    { "type": "header", "label": "İçerik" },
    { "type": "text", "id": "eyebrow", "label": "Üst başlık", "placeholder": "BAŞLAYIN" },
    { "type": "text", "id": "heading", "label": "Başlık", "bindable": true },
    { "type": "textarea", "id": "body", "label": "Açıklama", "rows": 3 },

    { "type": "header", "label": "Düzen" },
    { "type": "alignment", "id": "alignment", "label": "Hizalama" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 200, "step": 8, "suffix": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 200, "step": 8, "suffix": "px" },

    { "type": "header", "label": "Butonlar" },
    { "type": "text", "id": "primary_button_label", "label": "Birincil buton metni" },
    { "type": "url", "id": "primary_button_url", "label": "Birincil buton bağlantısı", "visibleIf": "primary_button_label" },
    { "type": "text", "id": "secondary_button_label", "label": "İkincil buton metni" },
    { "type": "url", "id": "secondary_button_url", "label": "İkincil buton bağlantısı", "visibleIf": "secondary_button_label" },

    { "type": "header", "label": "Renk" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması" }
  ],
  "presets": [
    {
      "name": "CTA — Vurgulu",
      "settings": {
        "heading": "Birlikte çalışalım",
        "body": "Sorularınız için en kısa sürede dönüş yapıyoruz.",
        "alignment": "center",
        "color_scheme": "scheme-2",
        "primary_button_label": "İletişim",
        "primary_button_url": "/iletisim"
      }
    },
    {
      "name": "CTA — İki butonlu",
      "settings": {
        "heading": "Hemen başlayın",
        "body": "Birkaç dakikada hesabınızı oluşturun.",
        "alignment": "center",
        "color_scheme": "scheme-1",
        "primary_button_label": "Hesap aç",
        "primary_button_url": "/kayit",
        "secondary_button_label": "Demoyu izle",
        "secondary_button_url": "#"
      }
    }
  ]
}
{% endschema %}
