{%- liquid
  assign brand = globals.site_name | default: site.name
-%}
<footer class="site-footer">
  <div class="wrap">
    <div class="footer-col">
      <h4>{{ brand }}</h4>
      {% if globals.tagline %}<p>{{ globals.tagline }}</p>{% endif %}
    </div>

    {%- comment -%}
      Footer menu drives the link columns: a top-level item WITH children
      becomes its own titled column (e.g. Ürünler / Sektörler / Hizmetler);
      childless top-level items collapse into one "Bağlantılar" column.
    {%- endcomment -%}
    {%- if footer_nav and footer_nav.size > 0 -%}
      {%- for item in footer_nav -%}
        {%- if item.children and item.children.size > 0 -%}
          <div class="footer-col">
            <h4>{{ item.label }}</h4>
            {%- for child in item.children -%}
              <a href="{{ child.url | default: '#' }}">{{ child.label }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- assign has_flat = false -%}
      {%- for item in footer_nav -%}
        {%- unless item.children and item.children.size > 0 -%}{%- assign has_flat = true -%}{%- endunless -%}
      {%- endfor -%}
      {%- if has_flat -%}
        <div class="footer-col">
          <h4>Bağlantılar</h4>
          {%- for item in footer_nav -%}
            {%- unless item.children and item.children.size > 0 -%}
              <a href="{{ item.url | default: '#' }}">{{ item.label }}</a>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    <div class="footer-col">
      <h4>İletişim</h4>
      {% if globals.phone %}<a href="tel:{{ globals.phone | remove: ' ' }}">{{ globals.phone }}</a>{% endif %}
      {% if globals.email %}<a href="mailto:{{ globals.email }}">{{ globals.email }}</a>{% endif %}
      {% if globals.address %}<span>{{ globals.address }}</span>{% endif %}
    </div>

    {%- comment -%} Çalışma saatleri (#259/#323) — globals.opening_hours: { mon: {closed,open,close}, … }.
      Operatörün doldurduğu günleri gösterir; hiç doldurulmamışsa sütun çıkmaz. {%- endcomment -%}
    {%- assign oh = globals.opening_hours -%}
    {%- assign day_keys = 'mon,tue,wed,thu,fri,sat,sun' | split: ',' -%}
    {%- assign day_labels = 'Pazartesi,Salı,Çarşamba,Perşembe,Cuma,Cumartesi,Pazar' | split: ',' -%}
    {%- assign has_hours = false -%}
    {%- if oh -%}
      {%- for k in day_keys -%}
        {%- assign dd = oh[k] -%}
        {%- if dd -%}{%- if dd.closed or dd.open != blank -%}{%- assign has_hours = true -%}{%- endif -%}{%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    {%- if has_hours -%}
    <div class="footer-col">
      <h4>Çalışma saatleri</h4>
      {%- for k in day_keys -%}
        {%- assign dd = oh[k] -%}
        {%- if dd -%}
          {%- assign show = false -%}
          {%- if dd.closed -%}{%- assign show = true -%}{%- elsif dd.open != blank -%}{%- assign show = true -%}{%- endif -%}
          {%- if show -%}
          <span style="display:flex;justify-content:space-between;gap:1.5rem">
            <span>{{ day_labels[forloop.index0] }}</span>
            <span>{%- if dd.closed -%}Kapalı{%- else -%}{{ dd.open }}–{{ dd.close }}{%- endif -%}</span>
          </span>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

    {% if globals.social_links %}
      <div class="footer-col">
        <h4>Sosyal</h4>
        {%- for social in globals.social_links -%}
          {%- comment -%} whatsapp/whatsapp_message jenerik link değil → yüzen buton olarak ayrı render edilir. {%- endcomment -%}
          {%- unless social[0] == 'whatsapp' or social[0] == 'whatsapp_message' -%}
            {%- if social[1] and social[1] != blank -%}
              <a href="{{ social[1] }}" rel="noopener" target="_blank">{{ social[0] | capitalize }}</a>
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {% endif %}
  </div>

  <div class="wrap footer-legal">
    <span>© {{ 'now' | date: '%Y' }} {{ brand }}</span>
    {%- comment -%} Kurumsal künye (#323) — globals.corporate; yalnız dolu alanlar, hiç yoksa çıkmaz. {%- endcomment -%}
    {%- assign corp = globals.corporate -%}
    {%- assign has_corp = false -%}
    {%- if corp -%}
      {%- if corp.legal_title != blank or corp.tax_number != blank or corp.trade_registry_no != blank or corp.mersis_no != blank -%}{%- assign has_corp = true -%}{%- endif -%}
    {%- endif -%}
    {%- if has_corp -%}
    <span class="footer-legal__corporate" style="opacity:.7;font-size:.8rem">
      {%- if corp.legal_title != blank -%}{{ corp.legal_title }}{%- endif -%}
      {%- if corp.tax_number != blank -%} · Vergi No: {% if corp.tax_office != blank %}{{ corp.tax_office }} {% endif %}{{ corp.tax_number }}{%- endif -%}
      {%- if corp.trade_registry_no != blank -%} · Sicil No: {{ corp.trade_registry_no }}{%- endif -%}
      {%- if corp.mersis_no != blank -%} · MERSİS: {{ corp.mersis_no }}{%- endif -%}
    </span>
    {%- endif -%}
    {%- if globals.kvkk_url != blank or globals.privacy_url != blank or globals.terms_url != blank -%}
    <span class="footer-legal__links">
      {% if globals.kvkk_url and globals.kvkk_url != blank %}<a href="{{ globals.kvkk_url }}">KVKK</a>{% endif %}
      {% if globals.privacy_url and globals.privacy_url != blank %}<a href="{{ globals.privacy_url }}">Gizlilik</a>{% endif %}
      {% if globals.terms_url and globals.terms_url != blank %}<a href="{{ globals.terms_url }}">Kullanım Şartları</a>{% endif %}
    </span>
    {%- endif -%}
  </div>
</footer>

{%- comment -%} Yüzen WhatsApp butonu (#323) — globals.social_links.whatsapp (numara) + whatsapp_message
  (hazır mesaj). Numara dolu değilse çıkmaz (geriye uyumlu). wa.me yalnız rakam ister. {%- endcomment -%}
{%- assign wa = globals.social_links.whatsapp -%}
{%- if wa and wa != blank -%}
  {%- assign wa_num = wa | replace: '+', '' | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' -%}
  {%- assign wa_msg = globals.social_links.whatsapp_message | default: '' | url_encode -%}
  <a class="wa-float" href="https://wa.me/{{ wa_num }}{% if wa_msg != '' %}?text={{ wa_msg }}{% endif %}"
     target="_blank" rel="noopener" aria-label="WhatsApp'tan yaz"
     style="position:fixed;right:1rem;bottom:1rem;z-index:50;display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:9999px;background:#25D366;box-shadow:0 4px 14px rgba(0,0,0,.25)">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.042zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
  </a>
{%- endif -%}
