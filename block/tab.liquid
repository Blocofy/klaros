<div class="tab-content">
  {%- if block.settings.heading and block.settings.heading != blank -%}
    <h3 class="tab-content__title" data-yt-bind="heading">{{ block.settings.heading }}</h3>
  {%- endif -%}
  {%- if block.settings.image and block.settings.image != blank -%}
    <img class="tab-content__media" src="{{ block.settings.image | image_url: 'width=1200,format=webp' }}" alt="{{ block.settings.heading | default: block.settings.label }}" loading="lazy">
  {%- endif -%}
  {%- if block.settings.text and block.settings.text != blank -%}
    <div class="tab-content__text richtext__body" data-yt-bind="text">{{ block.settings.text | sanitize_html }}</div>
  {%- endif -%}
  {%- if block.settings.link_label and block.settings.link_label != blank -%}
    <a class="btn btn--secondary" data-yt-bind="link_label" href="{{ block.settings.link_url | default: '#' }}">{{ block.settings.link_label }}</a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Sekme",
  "settings": [
    { "type": "text", "id": "label", "label": "Sekme etiketi", "placeholder": "Sekme" },
    { "type": "text", "id": "heading", "label": "Başlık", "bindable": true },
    { "type": "richtext", "id": "text", "label": "İçerik", "bindable": true },
    { "type": "image", "id": "image", "label": "Görsel" },
    { "type": "text", "id": "link_label", "label": "Buton metni" },
    { "type": "url", "id": "link_url", "label": "Bağlantı", "visibleIf": "link_label" }
  ]
}
{% endschema %}
