{%- if block.settings.image and block.settings.image != blank -%}
  {%- if block.settings.url and block.settings.url != blank -%}
    <a href="{{ block.settings.url }}" target="_blank" rel="noopener noreferrer">
      <img src="{{ block.settings.image | image_url: 'width=320,format=webp' }}" alt="{{ block.settings.alt | default: 'Logo' }}" loading="lazy">
    </a>
  {%- else -%}
    <img src="{{ block.settings.image | image_url: 'width=320,format=webp' }}" alt="{{ block.settings.alt | default: 'Logo' }}" loading="lazy">
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Logo",
  "settings": [
    { "type": "image", "id": "image", "label": "Logo görseli" },
    { "type": "text", "id": "alt", "label": "Marka adı (alt text)" },
    { "type": "url", "id": "url", "label": "Bağlantı (opsiyonel)" }
  ]
}
{% endschema %}
