{%- liquid
  assign src = block.settings.image
  assign ratio = block.settings.aspect_ratio | default: 'auto'
  assign align = block.settings.alignment | default: 'center'
-%}
{% if src and src != blank %}
  {%- assign img = '<img src="' | append: src | image_url: 'width=1600,format=webp' | append: '" alt="' | append: block.settings.alt | append: '" loading="lazy" style="width:100%;height:auto;{% if ratio != ' | append: "'auto'" | append: ' %}aspect-ratio:' | append: ratio | append: ';object-fit:cover;{% endif %}">' -%}
  <figure class="block-image block-image--{{ align }}"
          style="margin:0;display:flex;justify-content:{% if align == 'left' %}flex-start{% elsif align == 'right' %}flex-end{% else %}center{% endif %}">
    <div style="max-width:100%;width:{{ block.settings.max_width | default: 100 }}%">
      {% if block.settings.link and block.settings.link != blank %}
        <a href="{{ block.settings.link }}">
          <img src="{{ src | image_url: 'width=1600,format=webp' }}"
               alt="{{ block.settings.alt }}"
               loading="lazy"
               style="width:100%;height:auto;{% if ratio != 'auto' %}aspect-ratio:{{ ratio }};object-fit:cover;{% endif %}border-radius:var(--brand-radius,.5rem)">
        </a>
      {% else %}
        <img src="{{ src | image_url: 'width=1600,format=webp' }}"
             alt="{{ block.settings.alt }}"
             loading="lazy"
             style="width:100%;height:auto;{% if ratio != 'auto' %}aspect-ratio:{{ ratio }};object-fit:cover;{% endif %}border-radius:var(--brand-radius,.5rem)">
      {% endif %}
      {% if block.settings.caption and block.settings.caption != blank %}
        <figcaption style="margin-top:.6rem;font-size:.85rem;opacity:.7;text-align:{{ align }}">{{ block.settings.caption }}</figcaption>
      {% endif %}
    </div>
  </figure>
{% endif %}

{% schema %}
{
  "name": "Görsel",
  "settings": [
    { "type": "image", "id": "image", "label": "Görsel" },
    { "type": "text", "id": "alt", "label": "Alternatif metin", "help": "Ekran okuyucular + SEO için.", "placeholder": "Resmi anlatan kısa bir cümle" },
    { "type": "url", "id": "link", "label": "Bağlantı (opsiyonel)" },
    { "type": "text", "id": "caption", "label": "Altyazı" },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "En-boy oranı",
      "options": [
        { "label": "Orijinal", "value": "auto" },
        { "label": "Kare (1:1)", "value": "1/1" },
        { "label": "Yatay (16:9)", "value": "16/9" },
        { "label": "Yatay (4:3)", "value": "4/3" },
        { "label": "Dikey (3:4)", "value": "3/4" }
      ]
    },
    { "type": "alignment", "id": "alignment", "label": "Hizalama" },
    { "type": "range", "id": "max_width", "label": "Genişlik", "min": 25, "max": 100, "step": 5, "suffix": "%" }
  ]
}
{% endschema %}
