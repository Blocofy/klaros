<li class="timeline-item">
  {%- if block.settings.date and block.settings.date != blank -%}
    <span class="timeline-item__date" data-yt-bind="date">{{ block.settings.date }}</span>
  {%- endif -%}
  {%- if block.settings.heading and block.settings.heading != blank -%}
    <h3 class="timeline-item__title" data-yt-bind="heading">{{ block.settings.heading }}</h3>
  {%- endif -%}
  {%- if block.settings.text and block.settings.text != blank -%}
    <div class="timeline-item__text richtext__body" data-yt-bind="text">{{ block.settings.text | sanitize_html }}</div>
  {%- endif -%}
</li>

{% schema %}
{
  "name": "Zaman çizelgesi öğesi",
  "settings": [
    { "type": "text", "id": "date", "label": "Tarih / etiket", "placeholder": "2024" },
    { "type": "text", "id": "heading", "label": "Başlık", "bindable": true },
    { "type": "richtext", "id": "text", "label": "Metin", "bindable": true }
  ]
}
{% endschema %}
