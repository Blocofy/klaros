{%- comment -%}
  Hero slider slide. Rendered inline by section/HeroSlider.liquid; this file
  carries the schema block that drives the editor fields.
{%- endcomment -%}
<div class="hero-slide">
  {%- if block.settings.heading and block.settings.heading != blank -%}
    <h2>{{ block.settings.heading }}</h2>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Slayt",
  "settings": [
    { "type": "image", "id": "image", "label": "Arkaplan görseli" },
    { "type": "text", "id": "eyebrow", "label": "Üst başlık", "maxLength": 40 },
    { "type": "text", "id": "heading", "label": "Başlık" },
    { "type": "textarea", "id": "subtitle", "label": "Alt metin", "rows": 2 },
    { "type": "alignment", "id": "alignment", "label": "Hizalama" },
    { "type": "text", "id": "button_label", "label": "Buton metni" },
    { "type": "url", "id": "button_url", "label": "Buton bağlantısı", "visibleIf": "button_label" }
  ]
}
{% endschema %}
