<figure class="testimonial">
  {%- if block.settings.quote and block.settings.quote != blank -%}
    <blockquote class="testimonial__quote">{{ block.settings.quote }}</blockquote>
  {%- endif -%}
  <figcaption class="testimonial__author">
    {%- if block.settings.avatar and block.settings.avatar != blank -%}
      <img class="testimonial__avatar" src="{{ block.settings.avatar | image_url: 'width=80,height=80,format=webp' }}" alt="">
    {%- endif -%}
    <div>
      {%- if block.settings.name -%}<div class="testimonial__name">{{ block.settings.name }}</div>{%- endif -%}
      {%- if block.settings.role -%}<div class="testimonial__role">{{ block.settings.role }}</div>{%- endif -%}
    </div>
  </figcaption>
</figure>

{% schema %}
{
  "name": "Müşteri yorumu",
  "settings": [
    { "type": "header", "label": "İçerik" },
    { "type": "textarea", "id": "quote", "label": "Alıntı", "rows": 4, "placeholder": "Müşterinin yorumu" },
    { "type": "header", "label": "Yazan" },
    { "type": "text", "id": "name", "label": "Ad Soyad", "placeholder": "Müşteri Adı" },
    { "type": "text", "id": "role", "label": "Ünvan / Şirket", "placeholder": "Pazarlama Direktörü, ACME" },
    { "type": "image", "id": "avatar", "label": "Avatar" }
  ]
}
{% endschema %}
